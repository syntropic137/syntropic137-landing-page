#!/usr/bin/env bash
# Pre-commit: reject AI-generated copy patterns in user-facing source files.
# Zero dependencies. Checked into the repo so every contributor gets it.
#
# Activate once:  git config core.hooksPath .githooks

set -euo pipefail

STAGED=$(git diff --cached --name-only --diff-filter=ACM -- \
  'src/**/*.tsx' 'src/**/*.ts' 'src/**/*.css' \
  'index.html' \
  'README.md')

if [ -z "$STAGED" ]; then
  exit 0
fi

FAIL=0

# --- Em dash check: literal U+2014 and CSS \2014 escape ---
if echo "$STAGED" | xargs grep -nE '—|\\0*2014' 2>/dev/null; then
  echo ""
  echo "BLOCKED: Em dashes (— or CSS \\2014) found in staged files."
  echo "Replace with a period, comma, or colon (or \\00b7 middle dot in CSS)."
  FAIL=1
fi

if [ "$FAIL" -ne 0 ]; then
  echo ""
  echo "Fix the above and re-stage before committing."
  exit 1
fi
